{
  "name": "@dsz-examaware/rpc",
  "version": "0.3.0",
  "description": "ExamAware JSON-RPC connection helpers",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup && tsc -b --force --emitDeclarationOnly",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "keywords": [
    "examaware",
    "rpc",
    "json-rpc"
  ],
  "author": "ExamAware",
  "license": "GPL-3.0-only",
  "devDependencies": {
    "@types/node": "^25.0.3",
    "rimraf": "^6.1.2",
    "tsup": "^8.5.1",
    "typescript": "~5.9.3"
  }
}
